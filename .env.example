# MCP API Gateway — environment configuration
# Copy to .env and supply real values. The gateway FAILS CLOSED if the required
# secrets are missing or too weak (it will not start with insecure defaults).

# --- REQUIRED secrets (min 32 bytes each) ---
# Signs portal JWTs. Generate: openssl rand -base64 48
JWT_SECRET=
# Bearer token the LLM/MCP client must present. Generate: openssl rand -base64 48
GATEWAY_TOKEN=

# --- Local admin login (optional) ---
# Local login is DISABLED unless ADMIN_PASSWORD is set (min 12 chars).
# Prefer OIDC/SSO in production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# --- OIDC / SSO (recommended in production) ---
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Role granted to SSO-authenticated users: admin | viewer
OIDC_DEFAULT_ROLE=admin
# Public base URL of THIS gateway, used to build the OIDC redirect URI.
PUBLIC_BASE_URL=

# --- Core ---
PORT=8080
DATABASE_PATH=./mcp-gateway.db
# DATABASE_URL=postgres://user:pass@host:5432/db   # overrides DATABASE_PATH

# --- Vault ---
# 'local' is implemented. aws/gcp/azure currently fail closed (not implemented).
VAULT_PROVIDER=local
VAULT_LOCAL_PATH=./secrets.json

# --- Egress / SSRF policy ---
# Comma-separated hostname allowlist for downstream calls (empty = any public host).
EGRESS_ALLOWLIST=
# Allow calls to private/loopback ranges. Required for the local demo; keep false in prod.
EGRESS_ALLOW_PRIVATE=false

# --- CORS (SSE endpoint) ---
# Comma-separated allowed origins (empty = none). Avoid '*' in production.
CORS_ALLOWED_ORIGINS=

# --- Observability ---
# Bearer token required to scrape /metrics (empty = open).
METRICS_TOKEN=

# --- Performance / resilience tuning ---
# TTL for the in-process topology cache (connections/endpoints). Busted on writes.
CONFIG_CACHE_TTL=5s
# TTL for cached vault secret lookups (short, since rotation is not event-driven).
SECRET_CACHE_TTL=30s
# TTL for cached idempotent GET tool responses (0 = disabled).
RESPONSE_CACHE_TTL=0s
# Database connection pool (matters for Postgres under load).
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
# Bounded retries (exponential backoff) for idempotent downstream calls.
DOWNSTREAM_RETRIES=2

# --- Demo ---
# Seed demo connections/endpoints on first boot (off by default).
SEED_DEMO_DATA=false

# --- TLS / mTLS (optional) ---
TLS_CERT_PATH=
TLS_KEY_PATH=
CLIENT_CA_PATH=
